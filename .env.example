COMPOSE_PROJECT_NAME=simbirstore
APP_ENV=local
HTTP_PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/simbirstore?sslmode=disable
JWT_SECRET=change-this-in-production-min-32-chars

# Порт nginx в prod-режиме (также передаётся в nginx.conf.template)
NGINX_PORT=80

# Имя сервиса бэкенда в Docker-сети (должно совпадать с именем сервиса в docker-compose.yml)
BACKEND_HOST=backend
