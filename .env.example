APP_ENV=local
HTTP_PORT=8080

# PostgreSQL
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:${POSTGRES_PORT:-5432}/simbirstore?sslmode=disable

JWT_SECRET=change-this-in-production-min-32-chars

# Порт nginx в prod-режиме
NGINX_PORT=80

# Имя сервиса бэкенда в Docker-сети
BACKEND_HOST=backend
