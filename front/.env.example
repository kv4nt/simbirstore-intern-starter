# Адрес бэкенда для Vite-прокси (/api/* будет уходить сюда)
#
# Запуск без Docker (npm run dev): бэкенд работает на хосте
VITE_API_TARGET=http://localhost:8080
#
# Запуск через Docker Compose: значение переопределяется автоматически в docker-compose.yml,
# эту строку менять не нужно.

# Порт Vite dev-сервера
VITE_PORT=5173

# Порт nginx в prod-режиме
NGINX_PORT=80
