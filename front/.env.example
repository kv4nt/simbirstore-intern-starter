# Адрес локального Go-бэкенда
# Должен совпадать с HTTP_PORT из корневого .env
# Скопируй: cp .env.example .env
VITE_API_TARGET=http://localhost:8080

# Порт Vite dev-сервера (и отображается в docker-compose)
VITE_PORT=5173

# Порт nginx в prod-режиме
NGINX_PORT=80

# Имя сервиса бэкенда в Docker-сети (должно совпадать с именем сервиса в docker-compose.yml)
BACKEND_HOST=backend
